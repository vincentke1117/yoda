    "eslint": "^9.0.0",
    "eslint-plugin-react-hooks": "^7.0.0",
    "fix-path": "^4.0.0",
    "framer-motion": "^12.33.0",
    "glob": "^13.0.6",
    "human-id": "^4.1.2",
