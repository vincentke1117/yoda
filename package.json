    "react-icons": "^5.5.0",
    "react-markdown": "^10.1.0",
    "react-resizable-panels": "^4.7.3",
    "react-syntax-highlighter": "^15.6.6",
    "react-window": "^2.2.4",
    "rehype-raw": "^7.0.0",
