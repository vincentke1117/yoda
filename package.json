    "yaml": "^2.9.0",
    "zod": "^4.3.6"
  },
  "dependencies": {
    "@parcel/watcher": "^2.5.6",
    "better-sqlite3": "^12.10.0",
    "node-pty": "1.1.0",
    "ssh2": "^1.17.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "node-pty",
      "electron"
    ],
    "ignoredBuiltDependencies": [
      "core-js",
      "cpu-features",
      "esbuild",
      "protobufjs",
      "ssh2"
    ]
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.{js,jsx,json,css}": [
      "prettier --write"
    ]
  }
