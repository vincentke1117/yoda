{
  "expo": {
    "name": "Yoda Mobile",
    "slug": "yoda-mobile",
    "scheme": "yodamobile",
    "icon": "../../src/assets/images/yoda/yoda-beta.iconset/icon_512x512@2x.png",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "ios": {
      "bundleIdentifier": "ai.lovstudio.yoda.mobile",
      "supportsTablet": true,
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSLocalNetworkUsageDescription": "Yoda Mobile connects directly to the Yoda desktop app when both devices are on the same local network.",
        "NSAppTransportSecurity": {
          "NSAllowsLocalNetworking": true
        }
      }
    },
    "android": {
      "package": "ai.lovstudio.yoda.mobile",
      "adaptiveIcon": {
        "backgroundColor": "#F7F7F2"
      }
    },
    "web": {
      "bundler": "metro"
    },
    "extra": {
      "eas": {
        "projectId": "a2a704fb-220c-452d-a752-44739fe0c58e"
      }
    },
    "owner": "markshawn2020"
  }
}
