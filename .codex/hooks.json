{
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "curl -sf -X POST -H \"Content-Type: application/json\" -H \"X-Yoda-Token: $YODA_HOOK_TOKEN\" -H \"X-Yoda-Pty-Id: $YODA_PTY_ID\" -H \"X-Yoda-Event-Type: stop\" -d @- \"http://127.0.0.1:$YODA_HOOK_PORT/hook\" || true"
          }
        ]
      }
    ]
  }
}
